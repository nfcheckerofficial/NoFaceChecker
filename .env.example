# Stripe — copia este archivo a .env y rellena tus claves.
# Obtén tus claves en: https://dashboard.stripe.com/test/apikeys

# Clave secreta (solo backend). NUNCA la expongas en el frontend.
STRIPE_SECRET_KEY=

# Secreto de firma del webhook.
STRIPE_WEBHOOK_SECRET=

# URL del frontend (Vite).
CLIENT_URL=http://localhost:5173

# Puerto del servidor de pagos.
PORT=4242

# Entorno. 'development' o 'production'.
NODE_ENV=development

# Clave publicable (frontend). Prefijo VITE_ para exponerla.
VITE_STRIPE_PUBLISHABLE_KEY=

# URL del servidor de pagos.
VITE_PAYMENTS_API=http://localhost:4242
