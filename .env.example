# --- REQUIRED (sin estos no funciona) ---
STRIPE_SECRET_KEY=sk_test_...
TELEGRAM_BOT_TOKEN=...

# --- SECURITY (RECOMENDADO en producción) ---
# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Si no se setea, el server usa un secreto público (RECHAZA arrancar en producción).
# Mínimo 32 caracteres.
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_BASE64_STRING

# Webhook de Stripe (Dashboard → Developers → Webhooks → Signing secret)
# Si falta, el server RECHAZA arrancar cuando STRIPE_SECRET_KEY está configurada.
STRIPE_WEBHOOK_SECRET=whsec_...

# Clave para promover un usuario a admin vía POST /api/admin/setup
# Si no se setea, el endpoint de setup queda deshabilitado.
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SETUP_KEY=

# Crypto payments via Oxapay (https://oxapay.com)
# Obtén tu Merchant API Key desde el dashboard de Oxapay.
# Si no se setea, los pagos crypto se deshabilitan (Stripe sigue funcionando).
OXAPAY_API_KEY=

# --- OPCIONAL ---
CLIENT_URL=http://localhost:5173
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_PAYMENTS_API=http://localhost:4242
PORT=4242
NODE_ENV=development
